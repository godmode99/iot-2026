{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DeviceStatus",
  "type": "object",
  "required": [
    "last_seen_at",
    "online_state",
    "battery_percent",
    "signal_quality",
    "gps_fix_state"
  ],
  "properties": {
    "last_seen_at": {
      "type": "string",
      "format": "date-time"
    },
    "online_state": {
      "type": "string",
      "enum": ["online", "offline", "unknown"]
    },
    "battery_percent": {
      "type": "number"
    },
    "signal_quality": {
      "type": "string"
    },
    "gps_fix_state": {
      "type": "string",
      "enum": ["fix", "no_fix", "unknown"]
    }
  },
  "additionalProperties": true
}

