{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TelemetryPayload",
  "type": "object",
  "required": [
    "device_id",
    "timestamp",
    "temperature_c",
    "turbidity_raw",
    "battery_percent",
    "battery_mv",
    "lat",
    "lng"
  ],
  "properties": {
    "device_id": {
      "type": "string"
    },
    "timestamp": {
      "oneOf": [
        {
          "type": "string",
          "format": "date-time"
        },
        {
          "type": "integer"
        },
        {
          "type": "number"
        }
      ]
    },
    "temperature_c": {
      "type": ["number", "null"]
    },
    "turbidity_raw": {
      "type": ["number", "null"]
    },
    "battery_percent": {
      "type": ["number", "null"]
    },
    "battery_mv": {
      "type": ["number", "null"]
    },
    "lat": {
      "type": ["number", "null"]
    },
    "lng": {
      "type": ["number", "null"]
    },
    "firmware_version": {
      "type": ["string", "null"]
    },
    "signal_quality": {
      "type": ["number", "null"]
    },
    "gps_fix_state": {
      "type": ["string", "null"]
    },
    "battery_variant": {
      "type": ["string", "null"]
    }
  },
  "additionalProperties": true
}
