# Staging-only environment template.
# Copy this file to `.env.staging.local` and fill real values there.
# Do not commit `.env.staging.local`.

# App and URLs
NODE_ENV=production
APP_URL=https://your-staging-dashboard.vercel.app
DASHBOARD_URL=https://your-staging-dashboard.vercel.app
BACKEND_URL=https://your-staging-backend.example.com
DASHBOARD_ALLOW_ACTOR_OVERRIDE=false

# Supabase
SUPABASE_URL=https://your-staging-project.supabase.co
SUPABASE_ANON_KEY=replace-me
SUPABASE_SERVICE_ROLE_KEY=replace-me
SUPABASE_DB_URL=postgresql://postgres:replace-me@db.your-staging-project.supabase.co:5432/postgres
NEXT_PUBLIC_SUPABASE_URL=https://your-staging-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-me
NEXT_PUBLIC_DEFAULT_LOCALE=th

# Backend auth and safety
ADMIN_API_TOKEN=replace-me
JWT_SECRET=replace-me
INGEST_SHARED_TOKEN=replace-me
ADMIN_ALLOW_INSECURE_DEV=false
INGEST_ALLOW_INSECURE_DEV=false
PROVISIONING_ALLOW_INSECURE_DEV=false
BACKEND_RATE_LIMIT_ENABLED=true
BACKEND_RATE_LIMIT_ADMIN_MAX=60
BACKEND_RATE_LIMIT_COMMAND_MAX=120
BACKEND_RATE_LIMIT_INGEST_MAX=240
BACKEND_RATE_LIMIT_PROVISIONING_MAX=60
BACKEND_RATE_LIMIT_MUTATING_MAX=120

# MQTT and broker
MQTT_BROKER_URL=mqtts://your-broker.example.com:8883
MQTT_USERNAME=replace-me
MQTT_PASSWORD=replace-me
MQTT_TOPIC_PREFIX=sb00/staging/devices

# Notifications
# Use `stub` until customer-facing delivery is ready.
NOTIFICATION_MODE=stub
ALERT_NOTIFY_MIN_INTERVAL_SEC=900
RESEND_API_KEY=replace-me
LINE_CHANNEL_ACCESS_TOKEN=replace-me
ALERT_EMAIL_TO=alerts-staging@example.com
ALERT_LINE_USER_ID=replace-me

# OTA
OTA_RELEASES_PATH=ops/ota-releases.json
OTA_RELEASE_CHANNEL=staging
OTA_SIGNING_KEY_PATH=C:/keys/sb00-staging-ota-signing.pem

# Optional mapping and UX
NEXT_PUBLIC_MAP_PROVIDER=mapbox
NEXT_PUBLIC_MAP_API_KEY=replace-me
